# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Test / coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# MNIST raw data (downloaded at runtime, not committed)
data/
*.gz
*.idx3-ubyte
*.idx1-ubyte

# Training artifacts that are large / regenerated
# NOTE: the small exported browser weights (web/weights.json) ARE committed.
training/runs/
*.npz
checkpoints/*
# The final trained model IS committed so downstream sessions can load it.
!checkpoints/mnist_from_scratch.npz

# Node / web tooling
node_modules/
web/node_modules/
web/dist/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
